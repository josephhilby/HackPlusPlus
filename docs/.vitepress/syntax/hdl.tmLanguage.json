{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "hdl",
  "scopeName": "source.hdl",
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#keywords"
    },
    {
      "include": "#chip-definition"
    },
    {
      "include": "#pin-assignments"
    },
    {
      "include": "#punctuation"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.hdl",
          "match": "//.*$"
        },
        {
          "name": "comment.block.hdl",
          "begin": "/\\*",
          "end": "\\*/"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.configuration.hdl",
          "match": "(?<=^|[^a-zA-Z0-9_])(CHIP|IN|OUT|PARTS)(?=[^a-zA-Z0-9_]|$)"
        }
      ]
    },
    "chip-definition": {
      "patterns": [
        {
          "match": "(?<=^|[^a-zA-Z0-9_])([A-Z][a-zA-Z0-9_]*)[^a-zA-Z0-9_]*(?=\\{|\\()",
          "captures": {
            "1": {
              "name": "entity.name.type.class.hdl"
            }
          }
        }
      ]
    },
    "pin-assignments": {
      "patterns": [
        {
          "match": "(?<=^|[^a-zA-Z0-9_])([a-zA-Z0-9_]+(?:\\[[0-9\\.]+\\])?)[^a-zA-Z0-9_]*(=)[^a-zA-Z0-9_]*([a-zA-Z0-9_]+(?:\\[[0-9\\.]+\\])?)",
          "captures": {
            "1": {
              "name": "variable.parameter.hdl"
            },
            "2": {
              "name": "keyword.operator.assignment.hdl"
            },
            "3": {
              "name": "variable.other.readwrite.hdl"
            }
          }
        }
      ]
    },
    "punctuation": {
      "patterns": [
        {
          "name": "punctuation.definition.variable.hdl",
          "match": "[{}();,]"
        }
      ]
    }
  }
}
